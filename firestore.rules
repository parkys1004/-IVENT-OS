rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      // Use email check for bootstrapped admin and DB check for promoted roles
      return isSignedIn() && (
        (request.auth.token.email == "aimaster1004@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
        data.uid is string && data.uid.size() <= 128 &&
        data.email is string && data.email.size() <= 256 &&
        data.role in ['user', 'host', 'dj', 'instructor', 'media', 'admin'] &&
        data.createdAt is timestamp &&
        (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
        (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
        (!('followersCount' in data) || data.followersCount is int);
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'description', 'category', 'date', 'endDate', 'locationName', 'maxAttendees', 'currentAttendees', 'hostId', 'hostName', 'status', 'createdAt']) &&
        data.title is string && data.title.size() <= 500 &&
        data.description is string && data.description.size() <= 20000 &&
        data.category is string && data.category.size() <= 100 &&
        data.date is timestamp &&
        data.endDate is timestamp &&
        data.locationName is string && data.locationName.size() <= 500 &&
        data.maxAttendees is int && data.maxAttendees > 0 &&
        data.currentAttendees is int && data.currentAttendees >= 0 &&
        data.hostId is string && data.hostId.size() <= 128 &&
        data.hostName is string && data.hostName.size() <= 200 &&
        data.status in ['draft', 'published', 'cancelled'] &&
        data.createdAt is timestamp &&
        (!('likesCount' in data) || data.likesCount is int) &&
        (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000)) &&
        (!('imageUrls' in data) || data.imageUrls is list);
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['eventId', 'userId', 'hostId', 'registeredAt', 'status']) &&
        data.eventId is string && data.eventId.size() <= 128 &&
        data.userId is string && data.userId == request.auth.uid &&
        data.hostId is string && data.hostId.size() <= 128 &&
        data.registeredAt is timestamp &&
        data.status in ['confirmed', 'cancelled'];
    }

    function isValidLike(data) {
      return data.keys().hasAll(['eventId', 'userId', 'createdAt']) &&
        data.eventId is string && data.eventId.size() <= 128 &&
        data.userId is string && data.userId == request.auth.uid &&
        data.createdAt is timestamp;
    }

    function isValidFollow(data) {
      return data.keys().hasAll(['followerId', 'followingId', 'createdAt']) &&
        data.followerId is string && data.followerId == request.auth.uid &&
        data.followingId is string && data.followingId.size() <= 128 &&
        data.followerId != data.followingId &&
        data.createdAt is timestamp;
    }

    function isValidPromoBanner(data) {
      return data.keys().hasAll(['imageUrl', 'isActive', 'updatedAt']) &&
        data.imageUrl is string && data.imageUrl.size() <= 1000000 &&
        data.isActive is bool &&
        data.updatedAt is timestamp &&
        (!('linkUrl' in data) || (data.linkUrl is string && data.linkUrl.size() <= 2000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn(); // Profiles are generally public for social features
      
      allow create: if isOwner(userId) && 
                    isValidUser(incoming()) && 
                    incoming().uid == userId &&
                    incoming().role != 'admin' &&
                    incoming().createdAt == request.time;
                    
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(incoming()) && 
                    incoming().uid == userId &&
                    incoming().createdAt == existing().createdAt &&
                    (isAdmin() || incoming().role == existing().role);
                    
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow get: if isValidId(eventId);
      allow list: if true;
      
      allow create: if isSignedIn() && 
                    isValidId(eventId) &&
                    isValidEvent(incoming()) && 
                    incoming().hostId == request.auth.uid &&
                    incoming().createdAt == request.time &&
                    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['host', 'admin', 'dj', 'instructor', 'media']);
                    
      allow update: if isValidId(eventId) && (
                    (isAdmin() && isValidEvent(incoming())) || 
                    (
                      isOwner(existing().hostId) &&
                      isValidEvent(incoming()) &&
                      incoming().hostId == existing().hostId &&
                      incoming().createdAt == existing().createdAt &&
                      // Action: General Update
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'date', 'endDate', 'locationName', 'formattedAddress', 'imageUrl', 'imageUrls', 'maxAttendees', 'status', 'likesCount', 'currentAttendees', 'geoPoint', 'djs', 'performances', 'tickets', 'coverImageIndex'])
                    ) || (
                      // Action: Registration Increment/Decrement
                      incoming().diff(existing()).affectedKeys().hasOnly(['currentAttendees']) &&
                      incoming().currentAttendees >= 0 &&
                      incoming().currentAttendees <= existing().maxAttendees
                    ) || (
                      // Action: Like Count update (Increment/Decrement)
                      incoming().diff(existing()).affectedKeys().hasOnly(['likesCount'])
                    ));
                    
      allow delete: if isAdmin() || (isOwner(existing().hostId) && existing().status == 'draft');
    }

    match /registrations/{registrationId} {
      allow get: if isSignedIn() && (
        registrationId.split('_')[1] == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.hostId == request.auth.uid ||
        isAdmin()
      );
      
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.hostId == request.auth.uid ||
        isAdmin()
      );
      
      allow create: if isSignedIn() && 
                    isValidId(registrationId) &&
                    isValidRegistration(incoming()) && 
                    registrationId == incoming().eventId + '_' + incoming().userId &&
                    incoming().registeredAt == request.time &&
                    exists(/databases/$(database)/documents/events/$(incoming().eventId));
                    
      allow update: if isSignedIn() && 
                    isValidRegistration(incoming()) && 
                    isOwner(existing().userId) && 
                    incoming().eventId == existing().eventId &&
                    incoming().userId == existing().userId &&
                    incoming().registeredAt == existing().registeredAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']);
                    
      allow delete: if isAdmin() || isOwner(existing().userId);
    }

    match /eventLikes/{likeId} {
      allow get: if isSignedIn() && (likeId.split('_')[1] == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                    isValidId(likeId) &&
                    isValidLike(incoming()) &&
                    likeId == incoming().eventId + '_' + incoming().userId &&
                    incoming().createdAt == request.time &&
                    exists(/databases/$(database)/documents/events/$(incoming().eventId));
                    
      allow delete: if isAdmin() || isOwner(likeId.split('_')[1]);
    }

    match /userFollowers/{followId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && 
                    isValidId(followId) &&
                    isValidFollow(incoming()) &&
                    followId == incoming().followerId + '_' + incoming().followingId &&
                    incoming().createdAt == request.time &&
                    exists(/databases/$(database)/documents/users/$(incoming().followingId));
                    
      allow delete: if isAdmin() || isOwner(followId.split('_')[0]);
    }

    match /promoBanners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(bannerId) && isValidPromoBanner(incoming());
    }
  }
}
