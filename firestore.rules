rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email in ["aimaster1004@gmail.com", "parkys1004@gmail.com"] && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
        data.uid is string && data.uid.size() <= 128 &&
        data.email is string && data.email.size() <= 256 &&
        data.role in ['user', 'host', 'dj', 'instructor', 'media', 'admin'] &&
        data.createdAt is timestamp &&
        (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
        (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000000)) &&
        (!('followersCount' in data) || data.followersCount is int) &&
        (!('shortBio' in data) || (data.shortBio is string && data.shortBio.size() <= 200)) &&
        (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
        (!('specialties' in data) || (data.specialties is string && data.specialties.size() <= 500)) &&
        (!('career' in data) || (data.career is string && data.career.size() <= 2000)) &&
        (!('portfolioUrl' in data) || (data.portfolioUrl is string && data.portfolioUrl.size() <= 1000)) &&
        (!('studioLocation' in data) || (data.studioLocation is string && data.studioLocation.size() <= 500)) &&
        (!('phone' in data) || (data.phone is string && data.phone.size() <= 50)) &&
        (!('profileUpdated' in data) || data.profileUpdated is bool) &&
        (!('priority' in data) || data.priority is int);
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'description', 'category', 'date', 'endDate', 'locationName', 'maxAttendees', 'currentAttendees', 'hostId', 'hostName', 'status', 'createdAt']) &&
        data.title is string && data.title.size() <= 500 &&
        data.description is string && data.description.size() <= 20000 &&
        data.category is string && data.category.size() <= 100 &&
        data.date is timestamp &&
        data.endDate is timestamp &&
        data.locationName is string && data.locationName.size() <= 500 &&
        data.maxAttendees is number && data.maxAttendees > 0 &&
        data.currentAttendees is number && data.currentAttendees >= 0 &&
        data.hostId is string && data.hostId.size() <= 128 &&
        data.hostName is string && data.hostName.size() <= 200 &&
        data.status in ['draft', 'published', 'cancelled'] &&
        data.createdAt is timestamp &&
        (!('updatedAt' in data) || data.updatedAt is timestamp) &&
        (!('likesCount' in data) || data.likesCount is number) &&
        (!('priority' in data) || data.priority is number) &&
        (!('isBanner' in data) || data.isBanner is bool) &&
        (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000000)) &&
        (!('imageUrls' in data) || data.imageUrls is list) &&
        (!('formattedAddress' in data) || (data.formattedAddress is string && data.formattedAddress.size() <= 1000)) &&
        (!('country' in data) || (data.country is string && data.country.size() <= 10)) &&
        (!('city' in data) || (data.city is string && data.city.size() <= 100)) &&
        (!('geoPoint' in data) || (data.geoPoint is map || data.geoPoint is latlng || data.geoPoint == null)) &&
        (!('djs' in data) || data.djs is list) &&
        (!('performances' in data) || data.performances is list) &&
        (!('tickets' in data) || data.tickets is list) &&
        (!('media' in data) || data.media is list) &&
        (!('paymentMethod' in data) || (data.paymentMethod is string && data.paymentMethod.size() <= 2000)) &&
        (!('coverImageIndex' in data) || data.coverImageIndex is number);
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['eventId', 'userId', 'hostId', 'registeredAt', 'status']) &&
        data.eventId is string && data.eventId.size() <= 128 &&
        data.userId is string && data.userId == request.auth.uid &&
        data.hostId is string && data.hostId.size() <= 128 &&
        data.registeredAt is timestamp &&
        data.status in ['confirmed', 'cancelled'] &&
        (!('isLesson' in data) || data.isLesson is bool);
    }

    function isValidPromoBanner(data) {
      return data.keys().hasAll(['imageUrl', 'isActive', 'updatedAt']) &&
        data.imageUrl is string && data.imageUrl.size() <= 1000000 &&
        data.isActive is bool &&
        data.updatedAt is timestamp &&
        (!('linkUrl' in data) || (data.linkUrl is string && data.linkUrl.size() <= 2000));
    }

    function isValidEventImage(data) {
      return data.keys().hasAll(['eventId', 'url', 'createdAt']) &&
        data.eventId is string && data.eventId.size() <= 128 &&
        data.url is string && data.url.size() <= 1000000 &&
        data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      
      allow create: if isOwner(userId) && 
                    isValidUser(incoming()) && 
                    incoming().uid == userId &&
                    (incoming().role != 'admin' || isAdmin()) &&
                    incoming().createdAt == request.time;
                    
      allow update: if (isAdmin() || isOwner(userId)) && 
                    isValidUser(incoming()) && 
                    incoming().uid == existing().uid &&
                    incoming().createdAt == existing().createdAt &&
                    (isAdmin() || incoming().role == existing().role);
                    
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    match /events/{eventId} {
      allow get: if isValidId(eventId);
      allow list: if true;
      
      allow create: if isSignedIn() && 
                    isValidId(eventId) &&
                    isValidEvent(incoming()) && 
                    incoming().hostId == request.auth.uid &&
                    incoming().createdAt == request.time &&
                    (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['host', 'dj', 'instructor', 'media']);
                    
      allow update: if isValidId(eventId) && isValidEvent(incoming()) && (
                    isAdmin() || 
                    (
                      isOwner(existing().hostId) &&
                      incoming().hostId == existing().hostId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'date', 'endDate', 'locationName', 'formattedAddress', 'country', 'city', 'imageUrl', 'imageUrls', 'maxAttendees', 'status', 'likesCount', 'currentAttendees', 'geoPoint', 'djs', 'performances', 'media', 'tickets', 'paymentMethod', 'coverImageIndex', 'updatedAt', 'hostName', 'hostId', 'createdAt', 'isBanner', 'priority'])
                    ) || (
                      // Action: Registration Increment/Decrement
                      isSignedIn() &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['currentAttendees']) &&
                      incoming().currentAttendees >= 0
                    ) || (
                      // Action: Like Count update
                      isSignedIn() &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['likesCount'])
                    ));
                    
      allow delete: if isAdmin() || (isOwner(existing().hostId) && existing().status == 'draft');
    }

    match /eventImages/{imageId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidEventImage(incoming()) && exists(/databases/$(database)/documents/events/$(incoming().eventId));
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/events/$(resource.data.eventId)) && isOwner(get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.hostId);
    }

    match /registrations/{registrationId} {
      allow get: if isSignedIn() && isValidId(registrationId) && (
        isAdmin() || 
        registrationId.split('_')[1] == request.auth.uid ||
        (resource != null && resource.data.hostId == request.auth.uid)
      );
      
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.hostId == request.auth.uid ||
        isAdmin()
      );
      
      allow create: if isSignedIn() && 
                    isValidId(registrationId) &&
                    isValidRegistration(incoming()) && 
                    registrationId == incoming().eventId + '_' + incoming().userId &&
                    incoming().registeredAt == request.time &&
                    exists(/databases/$(database)/documents/events/$(incoming().eventId));
                    
      allow update: if isSignedIn() && 
                    isValidRegistration(incoming()) && 
                    (isOwner(existing().userId) || isOwner(existing().hostId) || isAdmin()) && 
                    incoming().eventId == existing().eventId &&
                    incoming().userId == existing().userId &&
                    incoming().registeredAt == existing().registeredAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']);
                    
      allow delete: if isAdmin() || isOwner(existing().userId);
    }

    match /eventLikes/{likeId} {
      allow get: if isSignedIn() && isValidId(likeId) && (
        isAdmin() || 
        likeId.split('_')[1] == request.auth.uid
      );
      
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                    isValidId(likeId) &&
                    likeId == incoming().eventId + '_' + request.auth.uid &&
                    incoming().createdAt == request.time &&
                    exists(/databases/$(database)/documents/events/$(incoming().eventId));
                    
      allow delete: if isAdmin() || isOwner(likeId.split('_')[1]);
    }

    match /promoBanners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(bannerId);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
