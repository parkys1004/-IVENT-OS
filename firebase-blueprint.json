{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "description": "Base64 data URL or remote URL for profile picture" },
        "role": { "type": "string", "enum": ["user", "host", "admin", "dj", "instructor", "media"] },
        "followersCount": { "type": "number" },
        "createdAt": { "type": "timestamp" },
        "priority": { "type": "number", "description": "Display priority for professionals" },
        "shortBio": { "type": "string" },
        "description": { "type": "string" },
        "specialties": { "type": "string" },
        "career": { "type": "string" },
        "portfolioUrl": { "type": "string" },
        "studioLocation": { "type": "string" },
        "profileUpdated": { "type": "boolean" },
        "phone": { "type": "string" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Event": {
      "title": "Event",
      "description": "Details of an event created by a host",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "timestamp" },
        "endDate": { "type": "timestamp" },
        "locationName": { "type": "string" },
        "locationAddress": { "type": "string" },
        "imageUrl": { "type": "string" },
        "imageUrls": { "type": "array" },
        "djs": { "type": "array" },
        "performances": { "type": "array" },
        "tickets": { "type": "array" },
        "maxAttendees": { "type": "number" },
        "currentAttendees": { "type": "number" },
        "likesCount": { "type": "number" },
        "hostId": { "type": "string" },
        "hostName": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "cancelled"] },
        "createdAt": { "type": "timestamp" },
        "priority": { "type": "number", "description": "Display priority for events" }
      },
      "required": ["title", "description", "category", "date", "endDate", "locationName", "maxAttendees", "currentAttendees", "hostId", "hostName", "status", "createdAt"]
    },
    "Registration": {
      "title": "Registration",
      "description": "A user's registration for an event",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "userId": { "type": "string" },
        "hostId": { "type": "string" },
        "registeredAt": { "type": "timestamp" },
        "status": { "type": "string", "enum": ["confirmed", "cancelled"] }
      },
      "required": ["eventId", "userId", "hostId", "registeredAt", "status"]
    },
    "EventLike": {
      "title": "Event Like",
      "description": "A user's like for an event",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["eventId", "userId", "createdAt"]
    },
    "UserFollow": {
      "title": "User Follow",
      "description": "A follow relationship between users",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["followerId", "followingId", "createdAt"]
    },
    "PromoBanner": {
      "title": "Promo Banner",
      "description": "Promotional banners displayed on the dashboard",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "linkUrl": { "type": "string" },
        "isActive": { "type": "boolean" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["imageUrl", "isActive", "updatedAt"]
    },
    "DashboardConfig": {
      "title": "Dashboard Config",
      "description": "Settings for the participant dashboard layout",
      "type": "object",
      "properties": {
        "partiesLimit": { "type": "number" },
        "lessonsLimit": { "type": "number" },
        "instructorsLimit": { "type": "number" },
        "djMediaLimit": { "type": "number" },
        "sectionOrder": { "type": "array" }
      }
    },
    "CommunityPost": {
      "title": "Community Post",
      "description": "A post in the community board",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["free", "inquiry"] },
        "authorId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["title", "content", "category", "authorId", "createdAt"]
    },
    "EventComment": {
      "title": "Event Comment",
      "description": "A comment on a specific event",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["eventId", "authorId", "content", "createdAt"]
    },
    "EventReview": {
      "title": "Event Review",
      "description": "A rating and review for a specific event",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "authorId": { "type": "string" },
        "rating": { "type": "number", "description": "1 to 5" },
        "content": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["eventId", "authorId", "rating", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Stores event information"
    },
    "/registrations/{registrationId}": {
      "schema": { "$ref": "#/entities/Registration" },
      "description": "Stores event registrations"
    },
    "/eventLikes/{likeId}": {
      "schema": { "$ref": "#/entities/EventLike" },
      "description": "Stores user event likes"
    },
    "/userFollowers/{followId}": {
      "schema": { "$ref": "#/entities/UserFollow" },
      "description": "Stores user follow relationships"
    },
    "/promoBanners/{bannerId}": {
      "schema": { "$ref": "#/entities/PromoBanner" },
      "description": "Stores promotional banners"
    },
    "/settings/dashboard": {
      "schema": { "$ref": "#/entities/DashboardConfig" },
      "description": "Stores dashboard layout configuration"
    },
    "/communityPosts/{postId}": {
      "schema": { "$ref": "#/entities/CommunityPost" },
      "description": "Stores community board posts"
    },
    "/eventComments/{commentId}": {
      "schema": { "$ref": "#/entities/EventComment" },
      "description": "Stores comments on events"
    },
    "/eventReviews/{reviewId}": {
      "schema": { "$ref": "#/entities/EventReview" },
      "description": "Stores event reviews and ratings"
    }
  }
}
